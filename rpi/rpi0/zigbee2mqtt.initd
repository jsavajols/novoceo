#!/sbin/openrc-run

supervisor=supervise-daemon
description="Zigbee2MQTT"

command="/usr/bin/zigbee2mqtt"
export ZIGBEE2MQTT_DATA="/var/lib/zigbee2mqtt"

supervise_daemon_args="--stdout /var/log/zigbee2mqtt/zigbee2mqtt.log --stderr /var/log/zigbee2mqtt/zigbee2mqtt.log"

depend() {
    need net
}

start_pre() {
    checkpath --directory --owner root:root --mode 0755 /var/log/zigbee2mqtt
    checkpath --directory --owner root:root --mode 0755 /var/lib/zigbee2mqtt
}
